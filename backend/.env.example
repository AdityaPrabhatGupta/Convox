# 🌍 Server Configuration

PORT=5000

# 🗄️ Database

MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/convox?retryWrites=true&w=majority

# 🔐 Authentication

JWT_SECRET=your_super_secret_key
JWT_EXPIRE=30d

# 🌐 Client (for CORS / future use)

CLIENT_URL=http://localhost:3000

# 🧪 Environment Mode

NODE_ENV=development

# 🔑 Google Auth (Add later - optional)

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
